msgid "Select shipping methods (empty for all)"
msgstr "Оставьте поле пустым для всех типов доставок"

msgid "Enable for shipping methods"
msgstr "Для каких типов доставок отображать способ оплаты"

msgid "Online acquiring and payment processing."
msgstr "Интернет эквайринг и обработка платежей."

msgid "Allow customers to conveniently checkout directly with "
msgstr "Настройка приема электронных платежей через "

msgid "WooCommerce RBSPaymentAlfabankBY Checkout plugin"
msgstr "Оплата банковской картой"

msgid "Allows to use a payment gateway with the WooCommerce."
msgstr ""
"Позволяет использовать платежный шлюз с Инструментом электронной торговли "
"WooCommerce."

msgid "RBSPaymentAlfabankBY"
msgstr "RBSPaymentAlfabankBY"

msgid "Enable/Disable"
msgstr "Включен/Выключен"

msgid "In this mode no actual payments are processed."
msgstr "В этом режиме реальные платежи не обрабатываются."

msgid "Payments type"
msgstr "Тип платежей"

msgid "Login-API"
msgstr "Логин-API"

