# SSL Configuration
# This file is included in server blocks that need SSL

# SSL certificate paths (Let's Encrypt)
ssl_certificate /etc/nginx/ssl/live/$DOMAIN/fullchain.pem;
ssl_certificate_key /etc/nginx/ssl/live/$DOMAIN/privkey.pem;

# Fallback to self-signed certificate if Let's Encrypt is not available
# Uncomment these lines if you want to use self-signed certificates for development
# ssl_certificate /etc/nginx/ssl/self-signed.crt;
# ssl_certificate_key /etc/nginx/ssl/self-signed.key;

# SSL Protocols
ssl_protocols TLSv1.2 TLSv1.3;
ssl_prefer_server_ciphers on;

# SSL Ciphers
ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384';

# SSL Session
ssl_session_timeout 1d;
ssl_session_cache shared:SSL:50m;
ssl_session_tickets off;

# OCSP Stapling
ssl_stapling on;
ssl_stapling_verify on;
ssl_trusted_certificate /etc/nginx/ssl/live/$DOMAIN/chain.pem;
resolver 8.8.8.8 8.8.4.4 valid=300s;
resolver_timeout 5s;

# DH Parameters (generate with: openssl dhparam -out /etc/nginx/ssl/dhparam.pem 2048)
# ssl_dhparam /etc/nginx/ssl/dhparam.pem;
